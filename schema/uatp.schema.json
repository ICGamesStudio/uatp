{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uatp.dev/schema/uatp-0.1.schema.json",
  "title": "Universal Agent Task Protocol 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "version", "intent", "scope", "actions", "success_criteria", "output"],
  "properties": {
    "protocol": {
      "const": "uatp"
    },
    "version": {
      "const": "0.1"
    },
    "intent": {
      "$ref": "#/$defs/intent"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "include": { "$ref": "#/$defs/stringOrStringArray" },
        "exclude": { "$ref": "#/$defs/stringOrStringArray" },
        "boundaries": { "$ref": "#/$defs/stringOrStringArray" }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/action" }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "risk": { "enum": ["low", "medium", "high"] },
        "change": { "enum": ["none", "minimal", "moderate", "broad"] },
        "language": { "type": "string", "minLength": 1 },
        "style": { "type": "string", "minLength": 1 },
        "privacy": { "type": "string", "minLength": 1 },
        "max_tokens": { "type": "integer", "minimum": 1 }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format"],
      "properties": {
        "format": { "$ref": "#/$defs/outputFormat" },
        "language": { "type": "string", "minLength": 1 },
        "sections": { "$ref": "#/$defs/stringOrStringArray" },
        "include_sources": { "type": "boolean" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "intent": {
      "oneOf": [
        {
          "enum": [
            "debug_code",
            "review_code",
            "write_tests",
            "refactor_code",
            "summarize",
            "translate",
            "extract_information",
            "create_plan"
          ]
        },
        { "$ref": "#/$defs/extensionIdentifier" }
      ]
    },
    "action": {
      "oneOf": [
        {
          "enum": [
            "inspect",
            "run_tests",
            "patch",
            "summarize",
            "validate",
            "plan",
            "translate",
            "extract",
            "report"
          ]
        },
        { "$ref": "#/$defs/extensionIdentifier" }
      ]
    },
    "outputFormat": {
      "oneOf": [
        {
          "enum": [
            "diff_summary",
            "review_findings",
            "test_report",
            "plain_text",
            "markdown",
            "json",
            "plan"
          ]
        },
        { "$ref": "#/$defs/extensionIdentifier" }
      ]
    },
    "extensionIdentifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*/[a-z][a-z0-9_]*(?:_[a-z0-9]+)*$"
    },
    "stringOrStringArray": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      ]
    }
  }
}
